# =============================================================================
# Root .env.example
# Copy this file to .env at the root of the project.
#
# This file consolidates all env variables required by docker-compose.yml configurations.
# =============================================================================

# ─── DATABASE (MONGODB) ───────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secure_root_password_here
MONGODB_URI=mongodb://admin:secure_root_password_here@mongodb:27017/drivest_db?authSource=admin
DB_NAME=drivest_db

# ─── BACKEND SERVICE ──────────────────────────────────────────────────────────
PORT=5001
JWT_SECRET_TOKEN=your_jwt_secret_token_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_TOKEN=your_jwt_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Cloudinary
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Pusher
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=eu
PUSHER_USE_TLS=true

# Firebase
FIREBASE_SERVICE_ACCOUNT_B64=your_base64_encoded_firebase_service_account_json

# Nodemailer
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID=price_your_stripe_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# RapidAPI
RAPIDAPI_HOST=your_rapidapi_host.p.rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key

# Internal Endpoint for Backend to communicate with AI service
PYTHON_API_URL=http://ai:8000

# ─── AI SERVICE ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini
NODE_API_URL=http://backend:5001/ai/import-cars

# ─── FRONTEND SERVICE ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key_here
NEXT_PUBLIC_PUSHER_CLUSTER=eu
