# =============================================================================
# Root .gitignore for Drivest multi-service project
# Covers Backend, Frontend (Next.js), AI part (Python), and Docker directories.
# =============================================================================

# ─── System / OS Files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db


# ─── Editor & IDE Settings ───────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo


# ─── Node.js (Backend & Frontend) ────────────────────────────────────────────
node_modules/
/backend/node_modules/
/frontend/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Runtime / Temp directories
/backend/uploads/
/backend/logs/


# ─── Next.js Frontend ─────────────────────────────────────────────────────────
/frontend/.next/
/frontend/out/
/frontend/build/

# Next.js developer environment diagnostics
/frontend/.next-env.d.ts
/frontend/next-env.d.ts
/frontend/*.tsbuildinfo


# ─── Python AI Service ────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
/ai-part/__pycache__/
/ai-part/scrapers/__pycache__/
/ai-part/app/__pycache__/
/ai-part/scripts/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyd

# Virtual Environments
venv/
.venv/
env/
/ai-part/venv/
/ai-part/.venv/
/ai-part/env/

# Large Scraped outputs & Temp Data
/ai-part/scrapers/output.json
/ai-part/scrapers/copy.json
/ai-part/scrapers/output_test.json
/ai-part/output.json
/ai-part/logs/
/ai-part/data/raw/cars_data.json


# ─── Environment Configurations / Secrets ─────────────────────────────────────
# Ignore actual environment files containing production secrets/credentials.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

/backend/.env
/backend/.env.*
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
/ai-part/.env
/ai-part/.env.*

# Keep the example configuration files committed
!.env.example
!/backend/.env.example
!/frontend/.env.example
!/ai-part/.env.example


# ─── Docker Runtime Data ──────────────────────────────────────────────────────
# Exclude database directory volumes if mounted locally on host
/volumes/
/volumes/mongodb/
